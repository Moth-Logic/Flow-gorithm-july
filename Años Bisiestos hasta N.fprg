    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <comment text="(Y%4==0) and ((Y%100!=0) or (Y%100==0 and Y%400==0))&#13;&#10;&#13;&#10;Programa que imprime todos los a&#241;os bisiestos hasta un a&#241;o limite.&#13;&#10;&#13;&#10;Entradas restricciones: &#13;&#10;A&#241;o L&#237;mite, Entero mayor o igual a 1582.&#13;&#10;&#13;&#10;Salidas: Listado de a&#241;os bisiestos"/>
            <declare name="AL, i" type="Integer" array="False" size=""/>
            <output expression="&quot;Introduzca el a&#241;o l&#237;mite:&quot;" newline="True"/>
            <input variable="AL"/>
            <if expression="AL&gt;=1582">
                <then>
                    <for variable="i" start="1582" end="AL" direction="inc" step="1">
                        <if expression="Bisi(i)">
                            <then>
                                <output expression="i" newline="True"/>
                            </then>
                            <else/>
                        </if>
                    </for>
                </then>
                <else>
                    <output expression="&quot;Ese no sirve lol xd&quot;" newline="True"/>
                </else>
            </if>
        </body>
    </function>
    <function name="Bisi" type="Boolean" variable="Result">
        <parameters>
            <parameter name="VueltasalSol" type="Integer" array="False"/>
        </parameters>
        <body>
            <declare name="Result" type="Boolean" array="False" size=""/>
            <assign variable="Result" expression="(VueltasalSol%4==0) and ((VueltasalSol%100!=0) or (VueltasalSol%100==0 and VueltasalSol%400==0))"/>
        </body>
    </function>
</flowgorithm>
